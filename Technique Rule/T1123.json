{
  "technique": { "id": "T1123", "name": "Audio Capture" },
  "detection": { "id": "DET0221" },
  "analysis": { "id": "AN0619" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0035", "name": "Process Access / Registry Modification" },
      "description": "오디오 장치 접근 및 설정 변경. 레지스트리 키와 프로세스 접근을 우선순위로 적용.",
      "conditions": [
        {
          "type": "registry_audio_config",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [12, 13] },
          "filters": { "TargetObject": { "contains_any": ["MMDevices\\Audio", "Microphone"] } },
          "description": "오디오 장치 설정 변경."
        },
        {
          "type": "process_audio_access",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [10] },
          "filters": {
            "TargetImage": {
              "contains_any": ["audiodg.exe", "audio", "AudioEndpointBuilder"]
            }
          },
          "description": "오디오 서비스 프로세스 타겟 접근만."
        },
        {
          "type": "audio_api_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": {
              "contains_any": ["waveInOpen", "Start-SoundRecorder", "System.Media", "audio_record"]
            }
          },
          "description": "PowerShell 오디오 API 호출."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0039", "name": "File Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [11] }, "description": "오디오 캡처 파일(.wav, .tmp 등) 생성" },
      { "data_component": { "id": "DC0032", "name": "Process Creation" }, "source": "WinEventLog:Security", "channel": { "event_codes": [4688] } }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [12, 13, 10],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "window_seconds": 300, "note": "장치 접근 후 파일 저장까지의 시간을 고려하여 5분 설정" }
    },
    "feature_extraction_filters": {
      "target_process_allowlist": ["zoom.exe", "ms-teams.exe", "skype.exe", "obs64.exe", "audacity.exe"],
      "write_directory_allowlist": ["C:\\Users\\*\\Music\\", "C:\\Users\\*\\Documents\\Recordings\\", "C:\\Users\\*\\AppData\\Roaming\\Zoom\\"]
    },
    "semantic_templates": {
      "audio_capture": "프로세스({Image})가 {TargetObject}를 조작하여 오디오 캡처를 시도함"
    }
  }
}