{
  "technique": { "id": "T1057", "name": "Process Discovery" },
  "detection": { "id": "DET-T1057" },
  "analysis": { "id": "AN-T1057" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "실행 중 프로세스 목록 열거.",
      "conditions": [
        {
          "type": "tasklist_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["tasklist.exe"] }
          },
          "description": "tasklist 실행."
        },
        {
          "type": "wmic_process",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "wmic.exe" },
            "CommandLine": { "contains_any": ["process list", "process get"] }
          },
          "description": "wmic process list/get."
        },
        {
          "type": "get_process_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["Get-Process", "[System.Diagnostics.Process]::GetProcesses"] }
          },
          "description": "PowerShell Get-Process."
        }
      ]
    },
    "Supporting Events": []
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 30 }
    },
    "feature_extraction_filters": {
      "enum_tools": ["tasklist.exe", "Get-Process", "wmic process"]
    },
    "semantic_templates": {
      "process_discovery": "계정({User})이 실행 중 프로세스 목록을 {Image}로 조회함."
    }
  }
}
