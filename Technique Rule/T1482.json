{
  "technique": { "id": "T1482", "name": "Domain Trust Discovery" },
  "detection": { "id": "DET-T1482" },
  "analysis": { "id": "AN-T1482" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "도메인 신뢰 관계 열거.",
      "conditions": [
        {
          "type": "nltest_trusts",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "nltest.exe" },
            "CommandLine": { "contains_any": ["/domain_trusts", "/trusted_domains", "/dsgetfti"] }
          },
          "description": "nltest로 도메인 신뢰 조회."
        },
        {
          "type": "dsquery_trust",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "dsquery.exe" },
            "CommandLine": { "contains_any": ["trust", "forest"] }
          },
          "description": "dsquery로 trust 조회."
        },
        {
          "type": "get_adtrust_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["Get-ADTrust", "Get-DomainTrust", "Get-NetDomainTrust", "Get-ForestTrust"] }
          },
          "description": "PowerView / ActiveDirectory trust cmdlet."
        }
      ]
    },
    "Supporting Events": []
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 60 }
    },
    "feature_extraction_filters": {
      "trust_tools": ["nltest.exe", "dsquery.exe", "Get-ADTrust", "Get-DomainTrust"]
    },
    "semantic_templates": {
      "trust_discovery": "계정({User})이 {Image}/{Cmdlet}으로 도메인 신뢰 관계를 열거함."
    }
  }
}
