{
  "technique": { "id": "T1105", "name": "Ingress Tool Transfer" },
  "detection": { "id": "DET-T1105" },
  "analysis": { "id": "AN-T1105" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0082", "name": "Network Connection Creation" },
      "description": "외부에서 페이로드/도구 다운로드.",
      "conditions": [
        {
          "type": "download_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "CommandLine": {
              "contains_any": [
                "certutil -urlcache", "certutil.exe -urlcache",
                "certutil -decode", "certutil.exe -decode",
                "bitsadmin /transfer", "bitsadmin.exe /transfer",
                "curl http", "curl -o", "wget http",
                "Invoke-WebRequest", "iwr ", "Invoke-RestMethod",
                "Start-BitsTransfer", "DownloadFile", "DownloadString",
                "New-Object System.Net.WebClient", "New-Object Net.WebClient"
              ]
            }
          },
          "description": "다운로드 명령 커맨드라인."
        },
        {
          "type": "download_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": {
              "contains_any": [
                "DownloadString", "DownloadFile", "Invoke-WebRequest",
                "Invoke-RestMethod", "System.Net.WebClient",
                "Start-BitsTransfer", "System.Net.Http.HttpClient"
              ]
            }
          },
          "description": "PowerShell 다운로드 API 호출."
        },
        {
          "type": "file_create_from_net",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [15] },
          "description": "Sysmon EID 15 (FileCreateStreamHash) — mark-of-the-web 붙은 다운로드 파일."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0082", "name": "Network Connection Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [3] }, "description": "다운로드를 위한 아웃바운드 연결" },
      { "data_component": { "id": "DC0039", "name": "File Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [11] }, "description": "다운로드된 파일 생성" },
      { "data_component": { "id": "DC0051", "name": "DNS Query" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [22] }, "description": "원격 호스트명 DNS 질의" }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104, 15],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 30, "after_seconds": 120 }
    },
    "feature_extraction_filters": {
      "download_tools": ["certutil", "bitsadmin", "curl", "wget", "powershell", "Invoke-WebRequest"],
      "suspicious_dest_paths": ["\\Temp\\", "\\AppData\\", "\\Public\\", "\\ProgramData\\"],
      "suspicious_extensions": [".exe", ".dll", ".ps1", ".bat", ".hta", ".zip"]
    },
    "semantic_templates": {
      "ingress_transfer": "프로세스({Image})가 {DownloadTool}로 {URL}에서 {TargetPath}에 파일을 다운로드함."
    }
  }
}
