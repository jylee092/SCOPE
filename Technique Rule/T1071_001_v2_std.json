{
  "technique": {
    "id": "T1071.001",
    "name": "Web Protocols"
  },
  "detection": {
    "id": "DET0027"
  },
  "analysis": {
    "id": "AN0075"
  },
  "log_sources": {
    "Anchor Event": {
      "data_component": {
        "id": "DC0085",
        "name": "Network Traffic — HTTP Listen or Outbound Connection"
      },
      "description": "HTTP 프로토콜을 통한 C2 통신 또는 리스너 개방 이벤트. 두 가지 형태로 발생하며 우선순위 순으로 적용.",
      "conditions": [
        {
          "type": "http_listen",
          "source": "WinEventLog:Security",
          "channel": {
            "event_codes": [
              5154
            ]
          },
          "filters": {
            "SourcePort": {
              "in": [
                80,
                443,
                8000,
                8080,
                8443,
                4443,
                9001
              ]
            },
            "LayerName": {
              "contains": [
                "Listen"
              ]
            }
          },
          "description": "WFP(Windows Filtering Platform) Listen 이벤트. 비표준 HTTP 포트(8000 등)에 리스너가 열리면 PowerShell 또는 악성 프로세스가 인바운드 C2 채널 개방한 것. Application=System이며 ProcessGuid 없음 — Hostname + time_window로 연결."
        },
        {
          "type": "outbound_connection_sysmon",
          "source": "WinEventLog:Sysmon",
          "channel": {
            "event_codes": [
              3
            ]
          },
          "filters": {
            "DestinationPort": {
              "in": [
                80,
                443,
                8080,
                8443
              ]
            },
            "Image": {
              "not_contains": [
                "chrome.exe",
                "msedge.exe",
                "firefox.exe",
                "iexplore.exe",
                "curl.exe",
                "svchost.exe",
                "MicrosoftEdgeUpdate.exe"
              ]
            }
          },
          "description": "Sysmon Network Connection. 브라우저/정상 유틸리티 제외 후 HTTP(S) 포트로 아웃바운드 연결하는 비정상 프로세스. ProcessGuid로 EID 1/7과 체인 연결 가능."
        }
      ]
    },
    "Supporting Events": [
      {
        "data_component": {
          "id": "DC0082_bind",
          "name": "Network Port Bind"
        },
        "source": "WinEventLog:Security",
        "channel": {
          "event_codes": [
            5158
          ]
        },
        "filters": {
          "SourcePort": {
            "in": [
              80,
              443,
              8000,
              8080,
              8443,
              4443,
              9001
            ]
          }
        },
        "description": "WFP Bind 허용 이벤트. EID 5154와 거의 동시에 발생하며 같은 포트 공유. 5154 Anchor와 함께 발생 시 Listen 행위 확증. 단독으로는 Anchor 불가 — 정상 프로세스 bind도 동일 EID 생성."
      },
      {
        "data_component": {
          "id": "DC0016",
          "name": "Module Load — Network DLL"
        },
        "source": "WinEventLog:Sysmon",
        "channel": {
          "event_codes": [
            7
          ]
        },
        "filters": {
          "Image": {
            "contains": [
              "powershell.exe",
              "pwsh.exe"
            ]
          },
          "ImageLoaded": {
            "contains": [
              "httpapi.dll",
              "winhttp.dll",
              "ws232.dll",
              "mswsock.dll",
              "dnsapi.dll",
              "FWPUCLNT.DLL"
            ]
          }
        },
        "description": "PowerShell이 HTTP/네트워크 DLL을 로드하는 이벤트. httpapi.dll: HTTP 서버 API 직접 사용(HttpListener), winhttp.dll/wininet.dll: 아웃바운드 HTTP 요청. EID 5154 Anchor와 time_window + Hostname으로 연결. ProcessGuid로 EID 22와 직접 연결 가능."
      },
      {
        "data_component": {
          "id": "DC0051",
          "name": "DNS Query"
        },
        "source": "WinEventLog:Sysmon",
        "channel": {
          "event_codes": [
            22
          ]
        },
        "filters": {
          "Image": {
            "contains": [
              "powershell.exe",
              "pwsh.exe"
            ]
          }
        },
        "description": "PowerShell의 DNS 쿼리. HTTP 리스너 개방 직전 자신의 IP를 조회하거나(WORKSTATION5 → 192.168.2.5), C2 도메인을 resolve하는 행위. ProcessGuid로 EID 7(DLL Load)과 동일 PowerShell 세션 확인 가능."
      },
      {
        "data_component": {
          "id": "DC0063",
          "name": "Registry Key — Network Parameters"
        },
        "source": "WinEventLog:Sysmon",
        "channel": {
          "event_codes": [
            12,
            13
          ]
        },
        "filters": {
          "TargetObject": {
            "contains": [
              "Tcpip\\Parameters",
              "Winsock"
            ]
          },
          "Image": {
            "contains": [
              "powershell.exe",
              "pwsh.exe"
            ]
          }
        },
        "description": "PowerShell이 TCP/IP 또는 Winsock 관련 레지스트리 키를 생성/수정. HTTP 리스너 초기화 시 네트워크 스택 설정 변경 과정에서 발생. EID 5154 직전에 나타나면 리스너 설정 행위로 해석."
      },
      {
        "data_component": {
          "id": "DC0082_connection",
          "name": "Network Connection Allowed"
        },
        "source": "WinEventLog:Security",
        "channel": {
          "event_codes": [
            5156
          ]
        },
        "filters": {
          "DestPort": {
            "in": [
              80,
              443,
              8080,
              8443
            ]
          },
          "Direction": {
            "contains": [
              "Outbound"
            ]
          }
        },
        "description": "WFP 아웃바운드 연결 허용. Sysmon EID 3이 없는 환경에서 대체 사용. Application 필드로 연결 주체 프로세스 확인. 단, ProcessGuid 없으므로 ProcessId + Hostname으로 연결."
      }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [
        5154
      ],
      "secondary_anchor": {
        "event_codes": [
          3
        ],
        "required_filters": [
          "DestinationPort: HTTP ports",
          "Image: not in exclusions"
        ],
        "priority_note": "EID 5154 우선. Sysmon EID 3이 있는 환경에서는 EID 3을 대체 Anchor로 사용 가능."
      },
      "correlation_key": {
        "primary": [
          "Hostname"
        ],
        "secondary": [
          "ProcessGuid"
        ],
        "fallback": [
          "Hostname"
        ],
        "note": "EID 5154/5158은 Application=System, ProcessGuid 없음. Hostname + time_window가 유일한 그룹핑 수단. Supporting EID 7/22는 ProcessGuid 보유 — 같은 PowerShell 세션 내 이벤트로 묶임. EID 5156은 ProcessId로 연결(ProcessGuid 없음)."
      },
      "time_window": {
        "before_seconds": 60,
        "after_seconds": 30,
        "note": "실제 데이터: PowerShell DLL Load(EID 7) → EID 5154 Listen은 0.1초 이내 동시 발생. EID 22(DNS 쿼리)는 Listen 후 약 2초 후 발생. before 60초는 PowerShell 시작(EID 7) 포착, after 30초는 DNS 쿼리 포착에 충분."
      }
    },
    "feature_extraction_filters": {
      "suspicious_listen_ports": [
        8000,
        8080,
        8443,
        4443,
        9001,
        1234,
        4444
      ],
      "http_indicator_dlls": [
        "httpapi.dll",
        "winhttp.dll",
        "wininet.dll",
        "FWPUCLNT.DLL"
      ],
      "network_indicator_dlls": [
        "winhttp.dll",
        "wininet.dll",
        "ws2_32.dll"
      ],
      "process_name_exclusions": [
        "chrome.exe",
        "msedge.exe",
        "firefox.exe",
        "iexplore.exe",
        "curl.exe",
        "svchost.exe",
        "MicrosoftEdgeUpdate.exe",
        "WindowsAzureGuestAgent.exe"
      ],
      "user_agent_anomalies": [
        "python-requests",
        "curl/",
        "wget",
        "PowerShell",
        "Go-http-client",
        "libwww-perl"
      ],
      "outbound_byte_ratio_threshold": 1.5,
      "description": "suspicious_listen_ports: 비표준 포트에 Listen 시 C2 가능성 높음. http_indicator_dlls: PowerShell HTTP 리스너 행위 확증. process_name_exclusions: 정상 브라우저/유틸리티 제외. user_agent_anomalies: 비브라우저 User-Agent로 아웃바운드 시 의심."
    },
    "semantic_templates": {
      "http_listener": "PowerShell이 httpapi.dll을 로드하고 포트 {SourcePort}에 HTTP 리스너를 개방함 (EID 5154). DNS 쿼리({QueryName})로 자신의 IP를 조회한 후 인바운드 C2 채널 대기.",
      "outbound_c2": "프로세스({Image})가 HTTP(S) 포트 {DestPort}로 외부 {DestAddress}에 연결함. 브라우저 제외 후 비정상 프로세스 발신 확인.",
      "cooccurrence_confirm": "EID 5154(Listen) + EID 5158(Bind) + EID 7(httpapi.dll Load)가 동시 발생 — PowerShell HTTP 리스너 개방 행위 High 신뢰도로 확증."
    }
  }
}