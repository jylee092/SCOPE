{
  "technique": { "id": "T1033", "name": "System Owner/User Discovery" },
  "detection": { "id": "DET-T1033" },
  "analysis": { "id": "AN-T1033" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "현재 사용자/세션 정보 조회.",
      "conditions": [
        {
          "type": "whoami_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["whoami.exe", "qwinsta.exe", "query.exe", "quser.exe"] }
          },
          "description": "whoami / qwinsta / quser 실행."
        },
        {
          "type": "whoami_security",
          "source": "WinEventLog:Security",
          "channel": { "event_codes": [4688] },
          "filters": {
            "NewProcessName": { "contains_any": ["whoami.exe", "qwinsta.exe"] }
          },
          "description": "Security 채널 fallback."
        },
        {
          "type": "whoami_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["[System.Security.Principal.WindowsIdentity]", "$env:USERNAME", "$env:USERDOMAIN", "Get-ADUser -Identity $env"] }
          },
          "description": "PowerShell 환경변수/Identity 조회."
        }
      ]
    },
    "Supporting Events": []
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4688],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 30 }
    },
    "feature_extraction_filters": {
      "discovery_binaries": ["whoami.exe", "qwinsta.exe", "quser.exe", "query.exe"]
    },
    "semantic_templates": {
      "system_owner": "계정({User})이 {Image} 실행으로 현재 사용자 정보를 조회함."
    }
  }
}
