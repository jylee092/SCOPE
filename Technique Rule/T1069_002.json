{
  "technique": { "id": "T1069.002", "name": "Domain Groups Discovery" },
  "detection": { "id": "DET-T1069002" },
  "analysis": { "id": "AN-T1069002" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "도메인 그룹 열거.",
      "conditions": [
        {
          "type": "net_group_domain",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["net.exe", "net1.exe"] },
            "CommandLine": { "contains_any": ["group /domain", "group \"Domain Admins\"", "group \"Enterprise Admins\""] }
          },
          "description": "net group /domain 및 특정 권한 그룹 조회."
        },
        {
          "type": "get_adgroup_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["Get-ADGroup", "Get-ADGroupMember", "Get-DomainGroup", "Get-NetGroup", "Get-DomainGroupMember"] }
          },
          "description": "ActiveDirectory / PowerView 도메인 그룹 cmdlet."
        },
        {
          "type": "samr_rpc_group",
          "source": "WinEventLog:Security",
          "channel": { "event_codes": [4661] },
          "filters": {
            "ObjectType": { "contains_any": ["SAM_GROUP", "SAM_ALIAS"] }
          },
          "description": "SAMR 그룹 열거 RPC."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0082", "name": "Network Connection Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [3] }, "filters": { "DestinationPort": { "in": ["389", "445"] } }, "description": "LDAP 또는 SMB/RPC 연결" }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104, 4661],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 30, "after_seconds": 60 }
    },
    "feature_extraction_filters": {
      "high_priv_groups": ["Domain Admins", "Enterprise Admins", "Schema Admins"],
      "ad_cmdlets": ["Get-ADGroup", "Get-DomainGroup", "Get-NetGroup"]
    },
    "semantic_templates": {
      "domain_groups_discovery": "계정({User})이 {Image}/{Cmdlet}으로 도메인 그룹({GroupName})을 열거함."
    }
  }
}
