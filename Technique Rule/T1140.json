{
  "technique": { "id": "T1140", "name": "Deobfuscate/Decode Files or Information" },
  "detection": { "id": "DET-T1140" },
  "analysis": { "id": "AN-T1140" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "Base64 / 인코딩된 문자열 디코딩 또는 난독화 해제.",
      "conditions": [
        {
          "type": "base64_decode_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "CommandLine": {
              "contains_any": [
                "certutil -decode", "certutil.exe -decode",
                "FromBase64String", "ConvertFrom-Base64",
                "-EncodedCommand", "-enc ", "-EC "
              ]
            }
          },
          "description": "certutil -decode, Base64 변환, PS EncodedCommand."
        },
        {
          "type": "base64_decode_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": {
              "contains_any": [
                "FromBase64String",
                "[Convert]::FromBase64String",
                "System.Text.Encoding",
                "DeflateStream", "GzipStream"
              ]
            }
          },
          "description": "PowerShell Base64 / 압축 해제 호출."
        },
        {
          "type": "xor_decrypt_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": {
              "contains_any": ["-bxor", "for ($i=0;$i", "ForEach-Object { $_ -bxor"]
            }
          },
          "description": "XOR 기반 인라인 복호화."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0032", "name": "Process Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [1] }, "filters": { "CommandLine": { "contains": "-EncodedCommand" } }, "description": "디코딩 후 실행되는 자식 프로세스" }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 60 }
    },
    "feature_extraction_filters": {
      "encoding_apis": ["FromBase64String", "certutil -decode", "DeflateStream", "GzipStream"],
      "description": "T1027 난독화와 쌍으로 등장 시 강한 공격 신호."
    },
    "semantic_templates": {
      "deobfuscate": "프로세스({Image})가 {DecodeMethod}로 인코딩된 페이로드를 복호화함."
    }
  }
}
