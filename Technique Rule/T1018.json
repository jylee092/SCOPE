{
  "technique": { "id": "T1018", "name": "Remote System Discovery" },
  "detection": { "id": "DET-T1018" },
  "analysis": { "id": "AN-T1018" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "원격 호스트/DC 목록 열거.",
      "conditions": [
        {
          "type": "net_view",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["net.exe", "net1.exe"] },
            "CommandLine": { "contains": "view" }
          },
          "description": "net view / net view /domain."
        },
        {
          "type": "nltest_dclist",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "nltest.exe" },
            "CommandLine": { "contains_any": ["/dclist", "/dsgetdc", "/dnsgetdc"] }
          },
          "description": "nltest로 DC 목록 열거."
        },
        {
          "type": "svcctl_openscmanager",
          "source": "WinEventLog:Security",
          "channel": { "event_codes": [5145] },
          "filters": {
            "ShareName": { "contains": "IPC$" },
            "RelativeTargetName": { "contains_any": ["svcctl", "srvsvc"] }
          },
          "description": "원격 SCManager 접근 (find-localadmin 류 도구)."
        },
        {
          "type": "remote_scan_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["Get-ADComputer", "Get-NetComputer", "Test-NetConnection", "Find-LocalAdminAccess"] }
          },
          "description": "PowerShell / PowerView 원격 호스트 열거."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0082", "name": "Network Connection Creation" }, "source": "WinEventLog:Sysmon", "channel": { "event_codes": [3] }, "description": "원격 호스트에 대한 연결 시도" }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104, 5145],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "secondary": ["norm_logon_id"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 30, "after_seconds": 120 }
    },
    "feature_extraction_filters": {
      "remote_enum_tools": ["net view", "nltest", "Get-ADComputer", "Find-LocalAdminAccess"]
    },
    "semantic_templates": {
      "remote_discovery": "계정({User})이 {Image}/{Cmdlet}으로 원격 호스트 또는 DC를 열거함."
    }
  }
}
