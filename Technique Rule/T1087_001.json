{
  "technique": { "id": "T1087.001", "name": "Local Account Discovery" },
  "detection": { "id": "DET-T1087001" },
  "analysis": { "id": "AN-T1087001" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "로컬 계정 열거 커맨드.",
      "conditions": [
        {
          "type": "net_user_local",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["net.exe", "net1.exe"] },
            "CommandLine": { "contains_any": ["user", "users", "localgroup"], "not_contains": "/domain" }
          },
          "description": "net user / net localgroup (도메인 아님)."
        },
        {
          "type": "net_user_security",
          "source": "WinEventLog:Security",
          "channel": { "event_codes": [4688] },
          "filters": {
            "NewProcessName": { "contains_any": ["net.exe", "net1.exe"] },
            "CommandLine": { "contains_any": ["user", "users", "localgroup"], "not_contains": "/domain" }
          },
          "description": "Security 채널 fallback."
        },
        {
          "type": "seatbelt_local_enum",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "CommandLine": { "contains_any": ["Seatbelt.exe", "Seatbelt -group=user", "Get-LocalUser", "Get-LocalGroupMember"] }
          },
          "description": "Seatbelt 또는 PowerShell LocalUser cmdlet."
        }
      ]
    },
    "Supporting Events": [
      { "data_component": { "id": "DC0032", "name": "Process Creation" }, "source": "WinEventLog:Security", "channel": { "event_codes": [4688] }, "description": "보조 프로세스 정보" }
    ]
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4688],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "secondary": ["norm_logon_id"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 30, "after_seconds": 60 }
    },
    "feature_extraction_filters": {
      "enum_tools": ["net.exe", "net1.exe", "Seatbelt.exe", "Get-LocalUser"]
    },
    "semantic_templates": {
      "local_account_discovery": "계정({User})이 {Image}으로 로컬 계정/그룹 목록({Details})을 열거함."
    }
  }
}
