{
  "technique": { "id": "T1082", "name": "System Information Discovery" },
  "detection": { "id": "DET-T1082" },
  "analysis": { "id": "AN-T1082" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "OS/호스트 정보 조회.",
      "conditions": [
        {
          "type": "sysinfo_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["systeminfo.exe", "hostname.exe", "ver.exe", "set.exe"] }
          },
          "description": "systeminfo / hostname / ver 실행."
        },
        {
          "type": "wmic_os_query",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "wmic.exe" },
            "CommandLine": { "contains_any": ["os get", "computersystem get", "product get", "qfe get"] }
          },
          "description": "wmic로 OS 정보/패치/제품 조회."
        },
        {
          "type": "seatbelt_system",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "CommandLine": { "contains_any": ["Seatbelt.exe", "-group=system", "Get-ComputerInfo"] }
          },
          "description": "Seatbelt / Get-ComputerInfo."
        }
      ]
    },
    "Supporting Events": []
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 30 }
    },
    "feature_extraction_filters": {
      "sysinfo_binaries": ["systeminfo.exe", "hostname.exe", "wmic.exe", "Seatbelt.exe"]
    },
    "semantic_templates": {
      "system_info": "계정({User})이 {Image}로 호스트/OS 정보를 열거함."
    }
  }
}
