{
  "technique": { "id": "T1049", "name": "System Network Connections Discovery" },
  "detection": { "id": "DET-T1049" },
  "analysis": { "id": "AN-T1049" },
  "log_sources": {
    "Anchor Event": {
      "data_component": { "id": "DC0064", "name": "Command Execution" },
      "description": "네트워크 세션/연결 열거.",
      "conditions": [
        {
          "type": "netstat_cli",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains": "netstat.exe" }
          },
          "description": "netstat 실행."
        },
        {
          "type": "net_session",
          "source": "WinEventLog:Sysmon",
          "channel": { "event_codes": [1] },
          "filters": {
            "Image": { "contains_any": ["net.exe", "net1.exe"] },
            "CommandLine": { "contains_any": ["session", "use"] }
          },
          "description": "net session / net use."
        },
        {
          "type": "srvsvc_netsess_enum",
          "source": "WinEventLog:Security",
          "channel": { "event_codes": [5145] },
          "filters": {
            "ShareName": { "contains": "IPC$" },
            "RelativeTargetName": { "contains": "srvsvc" }
          },
          "description": "원격 SRVSVC NetSessEnum RPC 호출."
        },
        {
          "type": "get_nettcpconn_psh",
          "source": "WinEventLog:PowerShell",
          "channel": { "event_codes": [4104] },
          "filters": {
            "ScriptBlockText": { "contains_any": ["Get-NetTCPConnection", "Get-NetSession", "[System.Net.NetworkInformation.IPGlobalProperties]"] }
          },
          "description": "PowerShell 네트워크 연결 cmdlet."
        }
      ]
    },
    "Supporting Events": []
  },
  "mutable_elements": {
    "grouping_logic": {
      "primary_anchor_eids": [1, 4104, 5145],
      "correlation_key": { "primary": ["Hostname", "ProcessGuid"], "fallback": ["Hostname"] },
      "time_window": { "before_seconds": 10, "after_seconds": 60 }
    },
    "feature_extraction_filters": {
      "enum_tools": ["netstat.exe", "net session", "Get-NetTCPConnection", "srvsvc"]
    },
    "semantic_templates": {
      "net_connections": "계정({User})이 {Image}로 네트워크 세션/연결을 열거함."
    }
  }
}
